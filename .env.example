# --- Required secrets -------------------------------------------------------

# Discord user token used to authenticate the self-bot.
# NOTE: automating a user account ("self-botting") is against Discord's Terms
# of Service and can get the account banned. Use a throwaway account you are
# willing to lose, and only in servers where you have permission.
DISCORD_TOKEN=

# Anthropic API key for Claude. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Optional overrides -----------------------------------------------------

# Claude model to use. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8

# Path to the JSON character definition (persona, people, channels). Defaults to
# ./character.json. Copy character.example.json to character.json to get started.
# CHARACTER_FILE=./character.json

# Comma-separated channel IDs the bot is allowed to respond in.
# Leave empty to allow every channel. Overrides "allowedChannelIds" in the
# character file.
# ALLOWED_CHANNEL_IDS=1102669707645034599

# IANA timezone the bot treats as its local time when stamping message context
# (e.g. Europe/Copenhagen, America/New_York). Defaults to UTC.
# TIMEZONE=UTC

# Maximum number of turns retained per channel. Older turns are dropped once the
# cap is exceeded, on append and on load. Must be a positive integer. Defaults to 40.
# MAX_HISTORY_MESSAGES=40

# Path to the JSON file conversation history is persisted to so chats resume
# across restarts. Defaults to ./data/history.json.
# HISTORY_FILE=./data/history.json

# Set to "true" for verbose logging of prompts and context.
# DEBUG=false
