# Dependencies & build output (rebuilt inside the image)
node_modules/
dist/

# Secrets & local state — never bake these into an image
.env
.env.local
*.local
character.json
reference-data.txt
data/
history.json.tmp

# VCS / editor / CI
.git/
.github/
.idea/
.ai/
.claude/

# Logs
*.log
npm-debug.log*

# Docs (not needed at runtime)
README.md
